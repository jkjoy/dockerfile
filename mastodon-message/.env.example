DRIVER=~fastapi+~httpx+~websockets
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# Reverse WebSocket is recommended.
# If you use forward WebSocket, uncomment and edit the line below.
# ONEBOT_WS_URLS=["ws://127.0.0.1:6700"]

SUPERUSERS=["123456789"]

MASTODON_ENABLED=true
MASTODON_TRANSPORT="streaming"
MASTODON_BASE_URL="https://mastodon.example"
MASTODON_ACCESS_TOKEN="replace-with-your-token"
MASTODON_STREAMING_URL=""
MASTODON_STREAM_RECONNECT_DELAY=5
MASTODON_STREAM_PING_INTERVAL=20
MASTODON_STREAM_PING_TIMEOUT=20
MASTODON_CHECK_INTERVAL=60
MASTODON_TIMEOUT=15
MASTODON_LIMIT=80
MASTODON_INCLUDE_FILTERED=false
MASTODON_EXCLUDE_TYPES=["follow","follow_request","update","admin.sign_up","admin.report"]
MASTODON_NOTIFY_PRIVATE_IDS=[123456789]
MASTODON_NOTIFY_GROUP_IDS=[]
MASTODON_ONEBOT_SELF_ID=""
MASTODON_STATE_FILE="data/mastodon_message_state.json"
MASTODON_INIT_SKIP_HISTORY=true
MASTODON_PREVIEW_LENGTH=160
MASTODON_MESSAGE_MAX_LENGTH=1600
